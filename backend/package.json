{
  "name": "backend",
  "version": "1.0.0",
  "description": "AI Task Extraction Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "fuser -k 3000/tcp 2>/dev/null; NODE_NO_WARNINGS=1 node server.js",
    "dev": "fuser -k 3000/tcp 2>/dev/null; NODE_NO_WARNINGS=1 node --watch server.js",
    "migrate": "node scripts/migrate.js"
  },

  "dependencies": {
